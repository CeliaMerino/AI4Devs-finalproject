PORT=3000
# Postgres local por defecto (puerto 5432)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/reading_analytics
# Si usas Docker del repo (puerto 5433): postgresql://postgres:postgres@localhost:5433/reading_analytics
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
# Recomendado para fallback si Open Library falla (cuota propia en Google Cloud)
GOOGLE_BOOKS_API_KEY=
